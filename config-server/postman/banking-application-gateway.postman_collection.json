{
  "info": {
    "name": "Banking Application - API Gateway",
    "_postman_id": "b3e7f2a1-4c8d-4e9f-a0b1-c2d3e4f5a6b7",
    "description": "All banking APIs routed through the API Gateway (port 8080).\n\nRouting Configuration:\n  /api/customers/** → customer-service (8081) - Customer operations\n  /api/accounts/**  → account-service (8082) - Account operations\n\nFeatures:\n  • Single entry point for all microservices\n  • Automatic route stripping (/api prefix removed before forwarding)\n  • Spring Cloud Gateway routing\n  • Service discovery via Eureka\n  • Circuit breaker (Resilience4j) for fault tolerance\n  • Distributed tracing with OpenTelemetry\n  • Spring Boot 4.0.4, Spring Cloud 2025.1.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",         "value": "http://localhost:8080",  "description": "API Gateway base URL" },
    { "key": "customerId",      "value": "",                       "description": "Populated automatically after Add Customer" },
    { "key": "accountId",       "value": "",                       "description": "Populated automatically after Create Account" },
    { "key": "depositAmount",   "value": "500.0",                  "description": "Amount to deposit" },
    { "key": "withdrawAmount",  "value": "200.0",                  "description": "Amount to withdraw" }
  ],
  "item": [
    {
      "name": "Customer Management",
      "description": "Routes: GET|POST|PUT|DELETE /api/customers/** → customer-service /customers/**",
      "item": [
        {
          "name": "Add Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has id', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body.id).to.be.a('number');",
                  "  pm.collectionVariables.set('customerId', body.id);",
                  "  console.log('customerId set to: ' + body.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"9876543210\",\n  \"address\": \"123 Main Street, Hyderabad\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"]
            },
            "description": "Creates a new customer. Automatically captures the returned `id` into the `customerId` variable."
          },
          "response": [
            {
              "name": "Success - 201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"9876543210\",\n  \"address\": \"123 Main Street, Hyderabad\"\n}"
            }
          ]
        },
        {
          "name": "Get All Customers",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is an array', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"]
            },
            "description": "Returns a list of all customers."
          },
          "response": [
            {
              "name": "Success - 200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"John Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"phone\": \"9876543210\",\n    \"address\": \"123 Main Street, Hyderabad\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Get Customer By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has correct id', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(String(body.id)).to.equal(String(pm.collectionVariables.get('customerId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "{{customerId}}"]
            },
            "description": "Returns a single customer by ID. Uses `{{customerId}}` variable."
          },
          "response": [
            {
              "name": "Success - 200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"9876543210\",\n  \"address\": \"123 Main Street, Hyderabad\"\n}"
            },
            {
              "name": "Not Found - 404",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Update Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Name is updated', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body.name).to.equal('John Doe Updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe Updated\",\n  \"email\": \"john.updated@example.com\",\n  \"phone\": \"9123456789\",\n  \"address\": \"456 New Street, Bengaluru\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "{{customerId}}"]
            },
            "description": "Updates an existing customer by ID."
          },
          "response": [
            {
              "name": "Success - 200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"name\": \"John Doe Updated\",\n  \"email\": \"john.updated@example.com\",\n  \"phone\": \"9123456789\",\n  \"address\": \"456 New Street, Bengaluru\"\n}"
            },
            {
              "name": "Not Found - 404",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Delete Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204 No Content', function () {",
                  "  pm.response.to.have.status(204);",
                  "});",
                  "console.log('Customer deleted. Associated accounts also deleted via account-service.');"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "{{customerId}}"]
            },
            "description": "Deletes a customer by ID. Also triggers deletion of all accounts for this customer in the account-service (cascade delete)."
          },
          "response": [
            {
              "name": "Success - 204 No Content",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            },
            {
              "name": "Not Found - 404",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "Account Management",
      "description": "Routes: GET|POST|DELETE /api/accounts/** → account-service /accounts/**\n\nNote: Add Money and Withdraw Money validate customer existence before processing.",
      "item": [
        {
          "name": "Create Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has id', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body.id).to.be.a('number');",
                  "  pm.collectionVariables.set('accountId', body.id);",
                  "  console.log('accountId set to: ' + body.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": {{customerId}},\n  \"balance\": 1000.0,\n  \"accountType\": \"SAVINGS\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts"]
            },
            "description": "Creates a new account for a customer. Uses `{{customerId}}` variable. Automatically captures the returned `id` into `accountId`."
          },
          "response": [
            {
              "name": "Success - 201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"customerId\": 1,\n  \"balance\": 1000.0,\n  \"accountType\": \"SAVINGS\"\n}"
            }
          ]
        },
        {
          "name": "Add Money",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns 400 if customer invalid', function () {",
                  "  if (pm.response.code === 400) {",
                  "    console.log('Customer validation failed or account not found.');",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}/add?amount={{depositAmount}}&customerId={{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}", "add"],
              "query": [
                { "key": "amount",     "value": "{{depositAmount}}",  "description": "Amount to deposit" },
                { "key": "customerId", "value": "{{customerId}}",     "description": "Customer ID for validation" }
              ]
            },
            "description": "Adds money to an account. Validates customer existence before processing. Returns 400 if customer is invalid or account not found."
          },
          "response": [
            {
              "name": "Success - 200 OK",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": ""
            },
            {
              "name": "Bad Request - 400 (invalid customer or account)",
              "status": "Bad Request",
              "code": 400,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Withdraw Money",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns 400 if customer invalid or insufficient balance', function () {",
                  "  if (pm.response.code === 400) {",
                  "    console.log('Customer validation failed, account not found, or insufficient balance.');",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}/withdraw?amount={{withdrawAmount}}&customerId={{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}", "withdraw"],
              "query": [
                { "key": "amount",     "value": "{{withdrawAmount}}", "description": "Amount to withdraw" },
                { "key": "customerId", "value": "{{customerId}}",     "description": "Customer ID for validation" }
              ]
            },
            "description": "Withdraws money from an account. Validates customer existence and checks sufficient balance. Returns 400 if customer is invalid, account not found, or balance is insufficient."
          },
          "response": [
            {
              "name": "Success - 200 OK",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": ""
            },
            {
              "name": "Bad Request - 400 (invalid customer, account, or insufficient balance)",
              "status": "Bad Request",
              "code": 400,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Get Account Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has account and customer details', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('balance');",
                  "  pm.expect(body).to.have.property('accountType');",
                  "  pm.expect(body).to.have.property('customer');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}"]
            },
            "description": "Returns full account details including the linked customer information fetched from customer-service."
          },
          "response": [
            {
              "name": "Success - 200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"balance\": 1300.0,\n  \"accountType\": \"SAVINGS\",\n  \"customer\": {\n    \"id\": 1,\n    \"name\": \"John Doe Updated\",\n    \"email\": \"john.updated@example.com\",\n    \"phone\": \"9123456789\",\n    \"address\": \"456 New Street, Bengaluru\"\n  }\n}"
            },
            {
              "name": "Not Found - 404",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Delete Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204 No Content', function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/{{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "{{accountId}}"]
            },
            "description": "Deletes an account by ID."
          },
          "response": [
            {
              "name": "Success - 204 No Content",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            },
            {
              "name": "Not Found - 404",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Delete Accounts By Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204 No Content', function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/accounts/deleteByCustomer/{{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts", "deleteByCustomer", "{{customerId}}"]
            },
            "description": "Deletes all accounts belonging to a customer. This is called internally by the customer-service during customer deletion, but can also be triggered manually."
          },
          "response": [
            {
              "name": "Success - 204 No Content",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            }
          ]
        }
      ]
    }
  ]
}
